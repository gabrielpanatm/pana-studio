{
  "name": "pana-studio",
  "version": "0.1.0",
  "description": "Editor vizual desktop open-source pentru site-uri Zola.",
  "author": "Gabriel Pană",
  "license": "EUPL-1.2-or-later",
  "private": true,
  "homepage": "https://github.com/gabrielpanatm/pana-studio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielpanatm/pana-studio.git"
  },
  "bugs": {
    "url": "https://github.com/gabrielpanatm/pana-studio/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:kernel": "svelte-kit sync && node --test --import ./tests/register-lib-alias-hooks.mjs tests/*.test.mjs",
    "test:preview-browser": "node tests/browser/canvas-runtime-real.mjs",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "licenses:check": "node scripts/generate-third-party-notices.mjs --check",
    "tauri": "scripts/tauri-with-local-appimage-runtime.sh"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@tabler/icons-svelte": "^3.41.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-image": "^3.23.1",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-table": "^3.23.1",
    "@tiptap/extension-table-cell": "^3.23.1",
    "@tiptap/extension-table-header": "^3.23.1",
    "@tiptap/extension-table-row": "^3.23.1",
    "@tiptap/extension-task-item": "^3.23.1",
    "@tiptap/extension-task-list": "^3.23.1",
    "@tiptap/markdown": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "tauri-pty": "^0.2.1"
  },
  "overrides": {
    "cookie": "0.7.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
