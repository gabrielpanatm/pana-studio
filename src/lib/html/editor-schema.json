    "cite": { "semantic": "url", "emptyPolicy": "preserve", "elements": ["blockquote"], "sourceEditable": true, "liveProjectable": true },
    "shape": { "semantic": "enumerated", "emptyPolicy": "remove", "elements": ["area"], "values": ["rect", "circle", "poly", "default"], "implicitValue": "rect", "sourceEditable": true, "liveProjectable": true },
    "coords": { "semantic": "numberList", "emptyPolicy": "remove", "elements": ["area"], "sourceEditable": true, "liveProjectable": true },

    "srcdoc": { "semantic": "string", "emptyPolicy": "preserve", "elements": ["iframe"], "sourceEditable": false, "liveProjectable": false, "previewMode": "blocked", "reason": "srcdoc poate injecta document activ și este blocat de Design Safe." }
  },
  "dynamicAttributes": {
    "data-*": { "semantic": "stringAllowEmpty", "emptyPolicy": "preserve", "sourceEditable": true, "liveProjectable": true },
    "aria-*": { "semantic": "ariaToken", "emptyPolicy": "preserve", "sourceEditable": true, "liveProjectable": true },
    "on*": { "semantic": "script", "emptyPolicy": "remove", "sourceEditable": false, "liveProjectable": false, "previewMode": "blocked" }
  }
}
